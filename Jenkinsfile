    agent any

    tools {
        nodejs "NodeJS-18"
    }

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/sowbagya-049/NodeJS-Jenkins.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build') {
            steps {
                sh 'echo Build Successful'
            }
        }

        stage('Test') {
            steps {
                sh 'echo Testing Successful'
            }
        }

        stage('Deploy') {
            steps {
                sh 'echo Deployment Successful'
            }
        }
    }
}
